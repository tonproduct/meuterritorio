@import "tailwindcss";

:root {
  --bg:           #0C1826;
  --bg-alt:       #111E2D;
  --bg-dark:      #0A1520;
  --surface:      #0F1D2B;
  --surface-card: #14263A;
  --border:       rgba(255, 255, 255, 0.07);
  --border-dk:    rgba(255, 255, 255, 0.14);
  --text:         #F0EDE8;
  --text-mid:     #8899AA;
  --text-dim:     #6B8299;
  --accent:       #C8A96E;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
}

/* ── NAV ── */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(12, 24, 38, 0.3);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  box-shadow: none;
  padding: 20px 40px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition:
    background 0.15s ease,
    backdrop-filter 0.15s ease,
    border-color 0.15s ease,
    box-shadow 0.15s ease;
}

.nav--scrolled {
  background: rgba(12, 24, 38, 0.72);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow:
    0 1px 0 rgba(255, 255, 255, 0.04),
    0 4px 24px rgba(0, 0, 0, 0.2);
}

.nav-logo {
  font-family: var(--font-label), sans-serif;
  font-size: 16px;
  font-weight: 300;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--text);
}

.nav-logo span {
  color: var(--accent);
}

.nav-logo__sub {
  font-size: 10px;
  font-weight: 400;
  letter-spacing: 0.18em;
  color: var(--text-dim);
  text-transform: uppercase;
  margin-left: 16px;
  padding-left: 16px;
  border-left: 1px solid var(--border-dk);
}

.nav-cta {
  font-family: var(--font-label), sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text);
  text-decoration: none;
  border: 1px solid var(--border-dk);
  padding: 9px 22px;
  border-radius: 3px;
  transition: border-color 0.2s, color 0.2s;
}

.nav-cta:hover {
  border-color: var(--accent);
  color: var(--accent);
}

/* ── SECTIONS ── */
section {
  padding: 100px 0;
  border-bottom: 1px solid var(--border);
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

.container--narrow {
  max-width: 860px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ── TYPOGRAPHY ── */
.hero-logo {
  height: 52px;
  width: auto;
  object-fit: contain;
  object-position: left center;
  margin-bottom: 24px;
  display: block;
  align-self: flex-start;
}

.hero-eyebrow {
  font-family: var(--font-label), sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 36px;
}

.hero-headline {
  font-family: var(--font-display), serif;
  font-size: clamp(32px, 3.8vw, 52px);
  font-weight: 700;
  line-height: 1.08;
  letter-spacing: -0.01em;
  color: var(--text);
  margin-bottom: 36px;
  max-width: 700px;
}

.hero-headline strong {
  font-weight: 400;
  font-style: italic;
  color: var(--text);
}

.hero-subheadline {
  font-size: 17px;
  font-weight: 300;
  line-height: 1.75;
  color: var(--text-mid);
  max-width: 540px;
  margin-bottom: 56px;
}

.section-title {
  font-family: var(--font-display), serif;
  font-size: clamp(32px, 4vw, 48px);
  font-weight: 700;
  line-height: 1.12;
  letter-spacing: -0.01em;
  margin-bottom: 32px;
  color: var(--text);
}

.section-title strong {
  font-weight: 400;
  font-style: italic;
}

.section-body {
  font-size: 16px;
  font-weight: 300;
  line-height: 1.85;
  color: var(--text-mid);
}

.section-body p + p {
  margin-top: 20px;
}

/* ── BUTTONS ── */
.btn-group {
  display: flex;
  gap: 16px;
  align-items: center;
  flex-wrap: wrap;
}

.btn-primary {
  display: inline-block;
  background: var(--text);
  color: var(--bg);
  font-family: var(--font-label), sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: 15px 36px;
  border-radius: 3px;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: opacity 0.2s;
}

.btn-primary:hover {
  opacity: 0.88;
}

.btn-ghost {
  display: inline-block;
  background: transparent;
  color: var(--text-mid);
  font-family: var(--font-label), sans-serif;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 15px 32px;
  border-radius: 3px;
  text-decoration: none;
  border: 1px solid var(--border-dk);
  cursor: pointer;
  transition: border-color 0.2s, color 0.2s;
}

.btn-ghost:hover {
  border-color: var(--text-mid);
  color: var(--text);
}

/* ── HERO ── */
#hero {
  padding: 140px 0 120px;
  background: var(--bg);
  position: relative;
  overflow: hidden;
}

/* Background layers */
.hero-bg-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

/* Imagem de fundo */
.hero-bg-layer::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url('/bg1.jpg');
  background-size: cover;
  background-position: center top;
  background-repeat: no-repeat;
  opacity: 0.22;
}

/* Overlay azul → transparente */
.hero-bg-layer::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    rgba(12, 24, 38, 0.92) 0%,
    rgba(12, 24, 38, 0.60) 40%,
    rgba(12, 24, 38, 0.0) 100%
  );
}

.hero-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(120px);
  z-index: 1;
}

.hero-glow--accent {
  width: 600px;
  height: 500px;
  top: -80px;
  right: -60px;
  background: radial-gradient(ellipse, rgba(200, 169, 110, 0.10) 0%, transparent 70%);
}

.hero-glow--blue {
  width: 500px;
  height: 400px;
  bottom: -100px;
  left: -80px;
  background: radial-gradient(ellipse, rgba(14, 85, 160, 0.14) 0%, transparent 70%);
}

.hero-dot-grid {
  position: absolute;
  inset: 0;
  z-index: 1;
  background-image: radial-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px);
  background-size: 28px 28px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
}

/* Hero two-column layout */
.hero-layout {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: 80px;
  align-items: center;
  padding-left: 0;
  padding-right: 0;
}

.hero-copy {
  display: flex;
  flex-direction: column;
}

/* Hero visual (right column) */
.hero-visual {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding-top: 8px;
}

/* ── CHAT STAGE ── */
.chat-stage {
  position: relative;
  width: 100%;
  max-width: 400px;
  min-height: 520px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

/* ── USER TRIGGER (fase 1) ── */
.user-trigger {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--surface-card);
  border: 1px solid var(--border-dk);
  border-radius: 40px;
  padding: 10px 20px 10px 10px;
  width: fit-content;
  transition: opacity 0.4s ease, transform 0.4s ease;
  box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 0 1px rgba(200,169,110,0.08);
}

.user-trigger--visible {
  opacity: 1;
  transform: translateY(0);
  animation: slideUpFade 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) 0.4s both;
}

.user-trigger--hidden {
  opacity: 0;
  transform: translateY(-8px);
  pointer-events: none;
  height: 0;
  padding: 0;
  border: none;
  overflow: hidden;
  transition: opacity 0.25s ease, transform 0.25s ease, height 0.3s ease, padding 0.3s ease;
}

.user-trigger__avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #1a2e40;
  border: 1px solid var(--border-dk);
  color: var(--text-mid);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display), serif;
  font-size: 13px;
  font-weight: 700;
  flex-shrink: 0;
}

.user-trigger__content {
  display: flex;
  align-items: center;
  gap: 8px;
}

.user-trigger__name {
  font-family: var(--font-label), sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--text);
}

.user-trigger__label {
  font-size: 11px;
  color: var(--text-dim);
  font-weight: 300;
}

.user-trigger__typing {
  display: flex;
  gap: 3px;
  align-items: center;
  margin-left: 2px;
}

.user-trigger__typing span {
  width: 5px;
  height: 5px;
  background: var(--accent);
  opacity: 0.6;
  border-radius: 50%;
  animation: wpp-bounce 1.1s infinite ease-in-out;
}
.user-trigger__typing span:nth-child(2) { animation-delay: 0.18s; }
.user-trigger__typing span:nth-child(3) { animation-delay: 0.36s; }

@keyframes slideUpFade {
  from { opacity: 0; transform: translateY(10px) scale(0.96); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

/* ── CHAT CARD (Hero) ── */
.chat-card {
  width: 100%;
  align-self: stretch;
  background: #0d1b28;
  border: 1px solid rgba(255, 255, 255, 0.10);
  border-radius: 16px;
  overflow: hidden;
  box-shadow:
    0 0 0 1px rgba(200, 169, 110, 0.06),
    0 32px 72px rgba(0, 0, 0, 0.55);
  position: relative;
  z-index: 1;
  transition: box-shadow 0.5s ease;
}

/* ── FASES ── */

/* p0 — oculto */
.chat-card--p0 {
  opacity: 0;
  transform: translateY(16px) scale(0.96);
  transition: opacity 0.4s ease, transform 0.4s ease;
}
.chat-card--p0 .chat-card__reasoning,
.chat-card--p0 .chat-card__expandable { display: none; }

/* p2 — raciocínio IA (Arthur analisando) */
.chat-card--p2 {
  opacity: 1;
  transform: translateY(0) scale(1);
  transition: opacity 0.45s cubic-bezier(0.34,1.56,0.64,1), transform 0.45s cubic-bezier(0.34,1.56,0.64,1);
}
.chat-card--p2 .chat-card__expandable { display: none; }
.chat-card--p2 .chat-card__reasoning {
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 20px 18px;
  animation: fadeIn 0.35s ease forwards;
}

/* p3 — abrindo */
.chat-card--p3 {
  opacity: 1;
  transform: translateY(0) scale(1);
}
.chat-card--p3 .chat-card__reasoning { display: none; }
.chat-card--p3 .chat-card__expandable {
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  animation: expandOpen 0.55s cubic-bezier(0.4,0,0.2,1) forwards;
}

/* p4 — chat rodando */
.chat-card--p4 {
  opacity: 1;
  transform: translateY(0) scale(1);
  transition: none;
}
.chat-card--p4 .chat-card__reasoning { display: none; }
.chat-card--p4 .chat-card__expandable {
  max-height: 500px;
  opacity: 1;
  overflow: hidden;
}

/* p5 — fechando: mesmo spring da abertura, em reverso */
.chat-card--p5 {
  opacity: 0;
  transform: translateY(16px) scale(0.96);
  transition:
    opacity 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) 0.35s,
    transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) 0.35s;
}
.chat-card--p5 .chat-card__reasoning { display: none; }
.chat-card--p5 .chat-card__expandable {
  max-height: 0 !important;
  opacity: 0;
  overflow: hidden;
  transition: max-height 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.25s ease;
}

/* ── REASONING PANEL ── */
.chat-card__reasoning {
  background: #0d1b28;
  padding: 20px 18px;
  display: none;
  flex-direction: column;
  gap: 14px;
}

.reasoning-lines {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.reasoning-line {
  height: 8px;
  width: var(--w, 70%);
  border-radius: 4px;
  background: linear-gradient(
    90deg,
    rgba(255,255,255,0.04) 0%,
    rgba(200,169,110,0.18) 40%,
    rgba(255,255,255,0.04) 100%
  );
  background-size: 200% 100%;
  animation: scanLine 1.6s ease-in-out var(--d, 0s) infinite;
}

.reasoning-label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-label), sans-serif;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent);
  opacity: 0.8;
}

.reasoning-spinner {
  width: 10px;
  height: 10px;
  border: 1.5px solid rgba(200,169,110,0.3);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.reasoning-ellipsis span {
  animation: ellipsisFade 1.4s ease-in-out infinite;
}
.reasoning-ellipsis span:nth-child(2) { animation-delay: 0.2s; }
.reasoning-ellipsis span:nth-child(3) { animation-delay: 0.4s; }

/* Avatar pulsando no thinking */
.chat-card__avatar--thinking {
  animation: avatarPulse 1.4s ease-in-out infinite;
}

/* Dot thinking (amarelo) */
.think-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
  animation: thinkerBlink 1s ease-in-out infinite;
}

/* ── KEYFRAMES ── */
@keyframes scanLine {
  0%   { background-position: 200% 0; opacity: 0.5; }
  50%  { background-position: -200% 0; opacity: 1; }
  100% { background-position: -200% 0; opacity: 0.5; }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes ellipsisFade {
  0%, 100% { opacity: 0.2; }
  50%       { opacity: 1; }
}

@keyframes avatarPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(200,169,110,0.4); }
  50%       { box-shadow: 0 0 0 6px rgba(200,169,110,0); }
}

@keyframes thinkerBlink {
  0%, 100% { opacity: 0.4; transform: scale(0.8); }
  50%       { opacity: 1;   transform: scale(1); }
}

@keyframes expandOpen {
  from { max-height: 0; opacity: 0; }
  to   { max-height: 500px; opacity: 1; }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(4px); }
  to   { opacity: 1; transform: translateY(0); }
}

.chat-card__header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px 20px;
  background: #111f2e;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.chat-card__avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), rgba(200, 169, 110, 0.55));
  color: #0C1826;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display), serif;
  font-size: 15px;
  font-weight: 700;
  flex-shrink: 0;
}

.chat-card__info {
  display: flex;
  flex-direction: column;
  gap: 3px;
  flex: 1;
}

.chat-card__name {
  font-family: var(--font-label), sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--text);
}

.chat-card__status {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  color: #25D366;
}

.chat-card__badge {
  color: #25D366;
  border: 1px solid rgba(37, 211, 102, 0.25);
  padding: 5px 7px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat-card__body {
  height: 380px;
  overflow-y: auto;
  padding: 16px 14px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  background: #0B141A;
  scroll-behavior: smooth;
}

.chat-card__body::-webkit-scrollbar { width: 2px; }
.chat-card__body::-webkit-scrollbar-track { background: transparent; }
.chat-card__body::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.07); border-radius: 2px; }

.chat-card__date {
  align-self: center;
  font-size: 10px;
  color: #8696A0;
  background: rgba(255,255,255,0.05);
  padding: 3px 10px;
  border-radius: 6px;
  font-family: var(--font-label), sans-serif;
  letter-spacing: 0.06em;
  margin-bottom: 4px;
}

.chat-card__row {
  display: flex;
  align-items: flex-end;
  gap: 7px;
  animation: msgFadeIn 0.3s ease forwards;
}

.chat-card__row--arthur { align-self: flex-start; }
.chat-card__row--user   { align-self: flex-end; flex-direction: row-reverse; }

.chat-card__bubble-avatar {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display), serif;
  font-size: 11px;
  font-weight: 700;
  align-self: flex-end;
}

.chat-card__bubble-avatar--arthur {
  background: linear-gradient(135deg, var(--accent), rgba(200,169,110,0.55));
  color: #0C1826;
}

.chat-card__bubble-avatar--user {
  background: #2a4a3e;
  color: rgba(255,255,255,0.5);
}

.chat-card__msg {
  max-width: 84%;
  padding: 9px 12px 22px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 400;
  line-height: 1.55;
  position: relative;
  animation: msgFadeIn 0.3s ease forwards;
}

.chat-card__msg p { margin: 0; }

.chat-card__msg--user {
  background: #005C4B;
  color: #E9EDF0;
  border-bottom-right-radius: 3px;
}

.chat-card__msg--arthur {
  background: #1F2C34;
  color: #E9EDF0;
  border-bottom-left-radius: 3px;
}

.chat-card__time {
  position: absolute;
  bottom: 5px;
  right: 10px;
  font-size: 10px;
  color: rgba(255,255,255,0.35);
  font-family: var(--font-label), sans-serif;
}

.chat-card__typing {
  align-self: flex-start;
  background: #1F2C34;
  border-radius: 8px;
  border-bottom-left-radius: 3px;
  padding: 10px 14px;
  display: flex;
  gap: 4px;
  align-items: center;
}

.chat-card__typing span {
  width: 6px;
  height: 6px;
  background: #8696A0;
  border-radius: 50%;
  animation: wpp-bounce 1.2s infinite ease-in-out;
}

.chat-card__typing span:nth-child(2) { animation-delay: 0.2s; }
.chat-card__typing span:nth-child(3) { animation-delay: 0.4s; }

.chat-card__footer {
  padding: 10px 14px;
  background: #111f2e;
  border-top: 1px solid rgba(255,255,255,0.06);
}

.chat-card__input {
  background: #2a3942;
  border-radius: 20px;
  padding: 9px 16px;
  font-size: 13px;
  color: rgba(255,255,255,0.2);
  font-weight: 300;
}

@keyframes msgFadeIn {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.hero-orb {
  position: absolute;
  width: 320px;
  height: 320px;
  border-radius: 50%;
  background: radial-gradient(ellipse, rgba(200, 169, 110, 0.07) 0%, transparent 70%);
  filter: blur(40px);
  z-index: 0;
}

/* Intelligence card */
.hero-card {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 380px;
  background: var(--surface-card);
  border: 1px solid var(--border-dk);
  border-radius: 16px;
  overflow: hidden;
  box-shadow:
    0 0 0 1px rgba(200, 169, 110, 0.06),
    0 24px 64px rgba(0, 0, 0, 0.45),
    0 4px 16px rgba(0, 0, 0, 0.3);
}

.hero-card__header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 18px 20px;
  border-bottom: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.025);
}

.hero-card__avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), rgba(200, 169, 110, 0.6));
  color: #0C1826;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display), serif;
  font-size: 15px;
  font-weight: 700;
  flex-shrink: 0;
}

.hero-card__name {
  font-family: var(--font-label), sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--text);
}

.hero-card__role {
  font-size: 11px;
  color: var(--text-dim);
  font-weight: 300;
  margin-top: 1px;
}

.hero-card__status {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: var(--font-label), sans-serif;
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.hero-card__body {
  padding: 20px 18px 14px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  min-height: 240px;
}

.hero-card__msg {
  max-width: 88%;
  padding: 10px 14px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 300;
  line-height: 1.55;
}

.hero-card__msg p { margin: 0; }

.hero-card__msg--in {
  background: rgba(255, 255, 255, 0.045);
  border: 1px solid var(--border);
  color: var(--text-mid);
  align-self: flex-start;
  border-bottom-left-radius: 3px;
}

.hero-card__msg--out {
  background: rgba(200, 169, 110, 0.10);
  border: 1px solid rgba(200, 169, 110, 0.18);
  color: var(--text);
  align-self: flex-end;
  font-style: italic;
  font-weight: 400;
  border-bottom-right-radius: 3px;
}

.hero-card__typing {
  align-self: flex-end;
  background: rgba(200, 169, 110, 0.08);
  border: 1px solid rgba(200, 169, 110, 0.14);
  border-radius: 10px;
  border-bottom-right-radius: 3px;
  padding: 10px 14px;
  display: flex;
  gap: 4px;
  align-items: center;
}

.hero-card__typing span {
  width: 5px;
  height: 5px;
  background: var(--accent);
  border-radius: 50%;
  opacity: 0.6;
  animation: wpp-bounce 1.2s infinite ease-in-out;
}

.hero-card__typing span:nth-child(2) { animation-delay: 0.2s; }
.hero-card__typing span:nth-child(3) { animation-delay: 0.4s; }

.hero-card__footer {
  padding: 12px 16px 16px;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  border-top: 1px solid var(--border);
}

.hero-card__tag {
  font-family: var(--font-label), sans-serif;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent);
  background: rgba(200, 169, 110, 0.08);
  border: 1px solid rgba(200, 169, 110, 0.16);
  padding: 4px 10px;
  border-radius: 20px;
}

.hero-availability {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 24px;
  font-family: var(--font-label), sans-serif;
  font-size: 11px;
  font-weight: 400;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.avail-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #25D366;
  flex-shrink: 0;
  box-shadow: 0 0 6px rgba(37, 211, 102, 0.5);
}

/* ── VANTAGEM ── */
#vantagem {
  background: var(--bg);
}

.pullquote {
  margin-top: 40px;
  padding: 28px 36px;
  border-left: 3px solid var(--accent);
  background: var(--surface-card);
  border-radius: 0 6px 6px 0;
}

.pullquote p {
  font-family: var(--font-display), serif;
  font-size: 20px;
  font-weight: 400;
  line-height: 1.7;
  color: var(--text-mid);
  font-style: italic;
}

.pullquote strong {
  color: var(--text);
  font-style: normal;
}

/* ── PROBLEMA ── */
#problema {
  background: var(--bg-alt);
}

/* ── ARTHUR ── */
#arthur {
  background: var(--bg);
}

.feature-list {
  margin-top: 40px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 14px 18px;
  border: 1px solid var(--border);
  border-radius: 5px;
  background: var(--surface-card);
}

.feature-icon {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--border-dk);
  flex-shrink: 0;
  margin-top: 7px;
}

.feature-item span {
  font-size: 14px;
  color: var(--text-mid);
  font-weight: 400;
}

/* ── COMO FUNCIONA ── */
#como-funciona {
  background: var(--bg-alt);
}

.timeline {
  margin-top: 56px;
  display: flex;
  flex-direction: column;
  position: relative;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 20px;
  top: 0;
  bottom: 0;
  width: 1px;
  background: var(--border-dk);
}

.timeline-step {
  display: flex;
  gap: 32px;
  align-items: flex-start;
  padding: 24px 0;
  border-bottom: 1px solid var(--border);
  position: relative;
}

.timeline-step:last-child {
  border-bottom: none;
}

.step-num {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--bg-dark);
  border: 2px solid var(--border-dk);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 700;
  color: var(--text-mid);
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.step-content h4 {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 5px;
}

.step-content p {
  font-size: 13px;
  color: var(--text-dim);
  font-weight: 300;
}

/* ── WHATSAPP MOCKUP ── */
.wpp-wrapper {
  display: flex;
  gap: 64px;
  align-items: center;
  max-width: 900px;
  margin-top: 64px;
  flex-wrap: wrap;
}

.wpp-context {
  flex: 1;
  min-width: 260px;
}

.wpp-context-label {
  font-family: var(--font-label), sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 16px;
}

.wpp-context-text {
  font-size: 16px;
  font-weight: 300;
  line-height: 1.8;
  color: var(--text-mid);
}

.wpp-phone {
  width: 320px;
  flex-shrink: 0;
  background: #0B141A;
  border-radius: 32px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 32px 64px rgba(0, 0, 0, 0.5);
}

.hero-phone.wpp-phone {
  width: 300px;
  border-radius: 40px;
  border: 8px solid #1a2a3a;
  box-shadow:
    0 0 0 1px rgba(255,255,255,0.06),
    0 40px 80px rgba(0,0,0,0.6),
    inset 0 0 0 1px rgba(255,255,255,0.04);
}

.wpp-notch {
  width: 100px;
  height: 6px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 3px;
  margin: 14px auto 0;
}

.wpp-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 20px;
  background: #1F2C34;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.wpp-avatar {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: var(--accent);
  color: #0C1826;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display), serif;
  font-size: 16px;
  font-weight: 700;
  flex-shrink: 0;
}

.wpp-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.wpp-name {
  font-family: var(--font-label), sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: #E9EDF0;
}

.wpp-status {
  font-size: 11px;
  color: #25D366;
  font-weight: 400;
}

.wpp-chat {
  padding: 16px 14px 20px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  background: #0B141A;
  min-height: 360px;
}

.wpp-date-label {
  text-align: center;
  font-size: 10px;
  color: #8696A0;
  background: rgba(255, 255, 255, 0.05);
  padding: 3px 10px;
  border-radius: 6px;
  align-self: center;
  margin-bottom: 6px;
  font-family: var(--font-label), sans-serif;
  letter-spacing: 0.06em;
}

.wpp-bubble {
  max-width: 82%;
  padding: 9px 12px 22px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 400;
  line-height: 1.55;
  position: relative;
}

.wpp-bubble--out {
  background: #005C4B;
  color: #E9EDF0;
  align-self: flex-end;
  border-bottom-right-radius: 3px;
}

.wpp-bubble--in {
  background: #1F2C34;
  color: #E9EDF0;
  align-self: flex-start;
  border-bottom-left-radius: 3px;
}

.wpp-time {
  position: absolute;
  bottom: 5px;
  right: 10px;
  font-size: 10px;
  color: rgba(255, 255, 255, 0.35);
  font-family: var(--font-label), sans-serif;
  font-weight: 400;
}

.wpp-typing {
  align-self: flex-start;
  background: #1F2C34;
  border-radius: 8px;
  border-bottom-left-radius: 3px;
  padding: 12px 16px;
  display: flex;
  gap: 4px;
  align-items: center;
}

.wpp-typing span {
  width: 6px;
  height: 6px;
  background: #8696A0;
  border-radius: 50%;
  animation: wpp-bounce 1.2s infinite ease-in-out;
}

.wpp-typing span:nth-child(2) {
  animation-delay: 0.2s;
}

.wpp-typing span:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes wpp-bounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30%            { transform: translateY(-4px); opacity: 1; }
}

/* ── FEATURES ── */
#features {
  background: var(--bg);
}

.features-grid {
  margin-top: 56px;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 16px;
}

.feat-card {
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 28px 24px;
  background: var(--surface-card);
  transition: border-color 0.2s;
}

.feat-card:hover {
  border-color: var(--border-dk);
}

.feat-card h4 {
  font-family: var(--font-display), serif;
  font-size: 17px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8px;
}

.feat-card p {
  font-size: 13px;
  font-weight: 300;
  color: var(--text-mid);
  line-height: 1.65;
}

.feat-tag {
  display: inline-block;
  font-family: var(--font-label), sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 10px;
}

/* ── PARA QUEM ── */
#para-quem {
  background: var(--bg-dark);
}

.profiles-grid {
  margin-top: 40px;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.profiles-grid + .profiles-grid {
  margin-top: 0;
}

.profile-chip {
  background: var(--surface-card);
  border: 1px solid var(--border-dk);
  color: var(--text);
  font-family: var(--font-label), sans-serif;
  font-size: 12px;
  font-weight: 400;
  letter-spacing: 0.06em;
  padding: 9px 20px;
  border-radius: 40px;
}

.profile-chip.negative {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--text-dim);
  text-decoration: line-through;
  opacity: 0.5;
}

.profiles-divider {
  width: 100%;
  height: 1px;
  background: var(--border);
  margin: 28px 0;
}

.profiles-not-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 14px;
}

/* ── AUTORIDADE ── */
#autoridade {
  background: var(--bg-alt);
}

.authority-box {
  margin-top: 40px;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 40px;
  background: var(--surface-card);
  display: flex;
  gap: 36px;
  align-items: flex-start;
}

.authority-avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: var(--surface);
  border: 2px solid var(--border-dk);
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display), serif;
  font-size: 28px;
  font-weight: 700;
  color: var(--accent);
}

.authority-text h3 {
  font-family: var(--font-display), serif;
  font-size: 22px;
  font-weight: 600;
  margin-bottom: 4px;
  color: var(--text);
}

.authority-text .role {
  font-family: var(--font-label), sans-serif;
  font-size: 10px;
  color: var(--accent);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  font-weight: 600;
  margin-bottom: 18px;
}

.authority-text p {
  font-size: 15px;
  font-weight: 300;
  line-height: 1.8;
  color: var(--text-mid);
}

.authority-text p + p {
  margin-top: 16px;
}

/* ── FECHAMENTO ── */
#fechamento {
  background: var(--bg-dark);
  text-align: center;
}

#fechamento .section-title {
  font-size: clamp(30px, 4.5vw, 52px);
  max-width: 680px;
  margin: 0 auto 28px;
}

#fechamento .section-body {
  max-width: 540px;
  margin: 0 auto 48px;
  font-size: 15px;
}

#fechamento .btn-group {
  justify-content: center;
}

/* ── SECTION INDICATOR ── */
.section-indicator {
  position: fixed;
  top: 50%;
  right: 0;
  transform: translateY(-50%);
  z-index: 200;
  background: var(--surface);
  border: 1px solid var(--border);
  border-right: none;
  border-radius: 8px 0 0 8px;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  width: 280px;
  box-shadow: -2px 0 16px rgba(0, 0, 0, 0.08);
  transition: transform 0.3s ease;
}

.section-indicator.collapsed {
  transform: translateY(-50%) translateX(252px);
}

.si-toggle {
  width: 28px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  border-right: 1px solid var(--border);
  color: var(--text-dim);
  font-size: 11px;
  background: var(--bg-alt);
  border-radius: 8px 0 0 8px;
  transition: background 0.2s;
  user-select: none;
}

.si-toggle:hover {
  background: var(--bg-dark);
}

.si-arrow {
  transition: transform 0.3s ease;
  display: inline-block;
}

.section-indicator.collapsed .si-arrow {
  transform: rotate(180deg);
}

.si-body {
  padding: 20px 18px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
  overflow: hidden;
}

.si-name {
  font-family: var(--font-label), sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent);
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
}

.si-desc {
  font-size: 12px;
  font-weight: 400;
  color: var(--text-mid);
  line-height: 1.65;
}

/* ── SECTION TESE (colapsada no Problema) ── */
.section-tese {
  font-family: var(--font-display), serif;
  font-size: 15px;
  font-weight: 400;
  font-style: italic;
  color: var(--text-dim);
  line-height: 1.75;
  margin-bottom: 40px;
  padding-bottom: 32px;
  border-bottom: 1px solid var(--border);
}

.section-tese strong {
  color: var(--text-mid);
  font-style: normal;
}

/* ── FEATURES GRID 3 ── */
.features-grid--3 {
  grid-template-columns: repeat(3, 1fr);
}

@media (max-width: 768px) {
  .features-grid--3 { grid-template-columns: 1fr; }
}

/* ── PROVA SOCIAL ── */
#prova-social { background: var(--bg-dark); }

.testimonials {
  margin-top: 48px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.testimonial {
  padding: 28px 32px;
  background: var(--surface-card);
  border: 1px solid var(--border);
  border-radius: 8px;
}

.testimonial__quote {
  font-family: var(--font-display), serif;
  font-size: 16px;
  font-weight: 400;
  font-style: italic;
  color: var(--text-mid);
  line-height: 1.8;
  margin-bottom: 20px;
}

.testimonial__author {
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.testimonial__name {
  font-family: var(--font-label), sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--text);
}

.testimonial__role {
  font-size: 12px;
  font-weight: 300;
  color: var(--text-dim);
}

/* ── ATIVAÇÃO ── */
#ativacao {
  background: var(--bg-dark);
}

.ativacao-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: stretch;
  margin-bottom: 72px;
}

/* Oferta / Preço */
.offer-price {
  margin: 36px 0 28px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.offer-price__label {
  font-family: var(--font-label), sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.offer-price__value {
  display: flex;
  align-items: baseline;
  gap: 4px;
}

.offer-price__currency {
  font-family: var(--font-label), sans-serif;
  font-size: 18px;
  font-weight: 400;
  color: var(--text-mid);
}

.offer-price__amount {
  font-family: var(--font-display), serif;
  font-size: 56px;
  font-weight: 700;
  color: var(--text);
  line-height: 1;
}

.offer-price__period {
  font-size: 16px;
  font-weight: 300;
  color: var(--text-mid);
}

.offer-includes {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 28px;
}

.offer-includes li {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  font-weight: 300;
  color: var(--text-mid);
}

.offer-check {
  color: var(--accent);
  font-size: 13px;
  font-weight: 700;
}

.offer-risk {
  font-family: var(--font-label), sans-serif;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
  padding-top: 20px;
  border-top: 1px solid var(--border);
}

/* Formulário */
.ativacao-form-wrap {
  background: var(--surface-card);
  border: 1px solid var(--border-dk);
  border-radius: 12px;
  padding: 32px;
  display: flex;
  flex-direction: column;
}

.ativacao-form-wrap .ativacao-form {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.ativacao-form-wrap .ativacao-form .form-field:last-of-type textarea {
  flex: 1;
  resize: none;
}

.ativacao-form-title {
  font-family: var(--font-label), sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 24px;
}

.ativacao-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.form-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-field label {
  font-family: var(--font-label), sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.form-optional {
  font-weight: 400;
  color: var(--text-dim);
  opacity: 0.6;
  text-transform: none;
  letter-spacing: 0;
}

.form-field input,
.form-field textarea {
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border-dk);
  border-radius: 6px;
  padding: 12px 14px;
  font-family: var(--font-body), sans-serif;
  font-size: 14px;
  font-weight: 300;
  color: var(--text);
  outline: none;
  transition: border-color 0.2s;
  resize: none;
}

.form-field input::placeholder,
.form-field textarea::placeholder {
  color: var(--text-dim);
}

.form-field input:focus,
.form-field textarea:focus {
  border-color: var(--accent);
}

.form-note {
  font-size: 12px;
  font-weight: 300;
  color: var(--text-dim);
  text-align: center;
}

/* FAQ */
.faq {
  border-top: 1px solid var(--border);
  padding-top: 56px;
}

.faq__title {
  font-family: var(--font-label), sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 32px;
}

.faq__list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px 48px;
}

.faq__item {}

.faq__q {
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8px;
}

.faq__a {
  font-size: 13px;
  font-weight: 300;
  color: var(--text-mid);
  line-height: 1.7;
}

@media (max-width: 768px) {
  .ativacao-layout { grid-template-columns: 1fr; gap: 48px; }
  .faq__list { grid-template-columns: 1fr; }
}

/* ── CAROUSEL ── */
#prova-social { background: var(--bg-alt); }

.carousel {
  margin-top: 48px;
}

.carousel-track {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.carousel-slide {
  animation: fadeIn 0.35s ease forwards;
}

.carousel-nav {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20px;
  margin-top: 36px;
}

.carousel-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--surface-card);
  border: 1px solid var(--border-dk);
  color: var(--text-mid);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  line-height: 1;
  transition: border-color 0.2s, color 0.2s;
}

.carousel-btn:hover:not(:disabled) {
  border-color: var(--accent);
  color: var(--accent);
}

.carousel-btn:disabled {
  opacity: 0.28;
  cursor: not-allowed;
}

.carousel-dots {
  display: flex;
  gap: 8px;
  align-items: center;
}

.carousel-dot {
  width: 6px;
  height: 6px;
  border-radius: 3px;
  background: var(--border-dk);
  border: none;
  cursor: pointer;
  transition: background 0.2s, width 0.2s;
  padding: 0;
}

.carousel-dot--active {
  background: var(--accent);
  width: 20px;
}

@media (max-width: 900px) {
  .carousel-track { grid-template-columns: 1fr; }
}

/* ── FAQ ACCORDION ── */
#faq { background: var(--bg); }

.faq-label {
  font-family: var(--font-label), sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 16px;
}

.faq-accordion {
  margin-top: 40px;
  border-top: 1px solid var(--border);
}

.faq-accordion__item {
  border-bottom: 1px solid var(--border);
}

.faq-accordion__trigger {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22px 0;
  cursor: pointer;
  background: none;
  border: none;
  text-align: left;
  color: var(--text);
  font-family: var(--font-body), sans-serif;
  font-size: 15px;
  font-weight: 500;
  gap: 16px;
  transition: color 0.2s;
}

.faq-accordion__trigger:hover {
  color: var(--accent);
}

.faq-accordion__icon {
  flex-shrink: 0;
  font-size: 22px;
  font-weight: 300;
  color: var(--text-dim);
  transition: transform 0.3s ease, color 0.2s;
  line-height: 1;
}

.faq-accordion__icon--open {
  transform: rotate(45deg);
  color: var(--accent);
}

.faq-accordion__body {
  overflow: hidden;
  transition: max-height 0.35s ease, opacity 0.25s ease;
}

.faq-accordion__body--open {
  max-height: 400px;
  opacity: 1;
}

.faq-accordion__body--closed {
  max-height: 0;
  opacity: 0;
}

.faq-accordion__answer {
  padding-bottom: 22px;
  font-size: 14px;
  font-weight: 300;
  color: var(--text-mid);
  line-height: 1.8;
}

/* ── FOOTER ── */
footer {
  padding: 36px 40px;
  border-top: 1px solid var(--border);
  text-align: center;
  background: var(--bg-dark);
}

footer p {
  font-family: var(--font-label), sans-serif;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-dim);
}

footer span {
  color: var(--accent);
  font-weight: 600;
}

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .hero-layout {
    grid-template-columns: 1fr;
    gap: 56px;
  }

  .hero-visual {
    order: -1;
  }

  .hero-card {
    max-width: 100%;
  }
}

@media (max-width: 640px) {
  .nav { padding: 16px 24px; }
  .container, .container--narrow { padding: 0 24px; }
  section { padding: 72px 0; }
  #hero { padding: 120px 0 72px; }
  .authority-box { flex-direction: column; }
  .wpp-phone { width: 100%; max-width: 320px; align-self: center; }
  .wpp-wrapper { flex-direction: column; gap: 40px; }
}
